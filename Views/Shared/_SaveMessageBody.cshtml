@using System.Security.Claims
@using Messenger.Tools
@using Newtonsoft.Json
@model IEnumerable<MessageSavedDto>
@{
    long selfUserId = long.Parse(User.FindFirst(ClaimTypes.NameIdentifier).Value);
    string[] AllowedImages = ViewData["allowedImagesExtention"] as string[] ?? [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tiff", ".webp"];
    var _baseUrl = ViewData["baseUrl"]?.ToString() ?? "";
}

<!-- header starts -->
<header id="header" class=" section-t-space main-header inner-page-header">
    <div class="custom-container">
        <div class="header-panel contact-panel">
            <div class="d-flex align-items-center gap-2">
                <a href="#" id="close-chat-panel-btn">
                    <i class="iconsax icon-btn" data-icon="chevron-left"> </i>
                </a>
                <div class="profile-head">
                     <div class="avatar bg-success text-light d-none d-sm-inline-block mr-3">
                        <span>
                             <i class="iconsax" data-icon="star-1"></i>
                        </span>
                    </div>
                    <div>
                        <h4 class="fw-semibold">پیام‌های ذخیره شده</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- header end -->
<!-- group chat section starts -->
<section class="section-lg-b-space position-relative pt-0" id="chat_content">
    <img class="img-fluid chat-bg" src="~/chatzy/assets/images/wallpaper/wallpaper0.png" alt="wallpaper">
    <div class="custom-container">
        <div id="Message_Days">
            @{
                var groupedMessages = Model
                    .OrderBy(m => m.Message.MessageDateTime)
                    .GroupBy(m => m.Message.MessageDateTime.Date);
            }
            @foreach (var group in groupedMessages)
            {
                <h6 class="fw-normal text-center heading pt-4">@group.Key.ToString("dddd, d MMMM yyyy", new System.Globalization.CultureInfo("fa-IR"))</h6>
                <ul class="message-box-list">
                    @foreach (var savedMessage in group)
                    {
                        var message = savedMessage.Message;
                        var isSelf = message.SenderUserId == selfUserId;

                        <li class="@(isSelf ? "personal" : "new")" id="message-@message.MessageId"
                            data-message-id="@message.MessageId"
                            data-sender-id="@message.SenderUserId">
                            <div class="message-box">
                                @if (!isSelf)
                                {
                                    <img class="img-fluid person-img" src="~/assets/media/avatar/@message.SenderUser.ProfilePicName" alt="p9">
                                }
                                <div class="message-box-details">
                                     <div class="d-flex justify-content-between">
                                        @if (!isSelf)
                                        {
                                            <span class="sender-name">@message.SenderUser.NameFamily</span>
                                        }
                                        <a href="#" class="actionDeleteSavedMessage" data-messagesavedid="@savedMessage.MessageSavedId" title="حذف از ذخیره شده ها">
                                            <i class="iconsax icon text-danger" data-icon="trash"></i>
                                        </a>
                                    </div>
                                    @if (message.ReplyMessageId != null)
                                    {
                                        <div class="reply-preview border p-2 rounded bg-light mb-2" style="cursor:pointer;" onclick="document.getElementById('message-@message.ReplyMessage?.MessageId')?.scrollIntoView({ behavior: 'smooth', block: 'center' });">
                                            <div class="text-muted small">پاسخ به: <strong>@message.ReplyMessage?.SenderUser.NameFamily</strong></div>
                                            <div class="text-truncate">@message.ReplyMessage?.MessageText?.MessageTxt</div>
                                        </div>
                                    }

                                    <h5>@Html.Raw(message.MessageText?.MessageTxt.Replace("\n", "<br />"))</h5>

                                    @if (message.MessageFiles?.Count > 0)
                                    {
                                        var imageFiles = message.MessageFiles.Where(f => AllowedImages.Contains(f.FileExtension.Extension, StringComparer.OrdinalIgnoreCase)).ToList();
                                        var otherFiles = message.MessageFiles.Where(f => !AllowedImages.Contains(f.FileExtension.Extension, StringComparer.OrdinalIgnoreCase)).ToList();

                                        if (imageFiles.Any())
                                        {
                                            <ul class="media-img">
                                                @foreach (var file in imageFiles)
                                                {
                                                    string fileTumbPath = System.IO.Path.Combine(_baseUrl, file.FileThumbPath);
                                                    <li class="p-0">
                                                        <a href="@fileTumbPath" data-fancybox="gallery-@message.MessageId">
                                                            <img class="img-fluid img-thumbnail" src="@fileTumbPath" alt="@file.OriginalFileName">
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        @foreach (var file in otherFiles)
                                        {
                                            string filePath = System.IO.Path.Combine(_baseUrl, file.FilePath);
                                            // Voice messages
                                            if (file.FileExtension.Extension == ".webm")
                                            {
                                                <div class="audio-player-container my-2">
                                                    <audio class="voice-player" src="@filePath" controls></audio>
                                                </div>
                                            }
                                            // Other files
                                            else
                                            {
                                                <div class="d-flex align-items-center gap-2 file-attachment-container p-2 rounded">
                                                    <div class="document-img">
                                                        <i class="iconsax" data-icon="document-text-1" style="font-size: 2em;"></i>
                                                    </div>
                                                    <div class="file-details">
                                                        <h5>@FileNameShorter.ShortenFileName(file.OriginalFileName ?? file.FileName, 20)</h5>
                                                        <h6>@file.FileExtension.Extension.ToUpper() | @FileSizeConverter.ConvertToReadableSize(file.FileSize)</h6>
                                                    </div>
                                                    <a href="#" class="btn-download-file ms-auto" data-file-id="@file.MessageFileId" data-file-originalName="@file.OriginalFileName">
                                                        <i class="iconsax" data-icon="arrow-down-to-bracket" style="font-size: 1.5em;"></i>
                                                    </a>
                                                </div>
                                            }
                                        }
                                    }

                                    <div class="timing">
                                        <h6>@message.MessageDateTime.ToString("HH:mm")</h6>
                                    </div>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
         <div class="chat-finished" id="chat-finished"></div>
    </div>
</section>
<!-- group chat section end -->
<script>
    if (window.init_iconsax) {
        window.init_iconsax();
    }
</script>
