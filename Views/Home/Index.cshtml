@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_ChatzyLayout.cshtml";
}
@using System.Security.Claims
@using Messenger.Tools

@section Styles {
   
}

<input type="hidden" value="@User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value" id="userId" />
<input type="hidden" value="@User.Claims.FirstOrDefault(c => c.Type == "NameFamily")?.Value" id="fullName" />
<input type="hidden" value="@(ViewData["userProfilePic"] ?? "UserIcon.png")" id="userProfilePic" />
<input type="hidden" value="@(ViewData["baseUrl"] ?? "")" id="baseUrl" />
<input type="hidden" value="" id="groupType" />

<div id="main-content-body">
    <!-- story section starts -->
    @*   <section class="story-section pt-0">
        <div class="left-container">
            <h6 class="content-color fw-medium">Recent Update</h6>
            <div class="swiper story-box">
                <div class="swiper-wrapper">
                    <!-- Story items can be loaded here if needed -->
                </div>
            </div>
        </div>
    </section> *@
    <!-- story section end -->
    <!-- chat section starts -->
    <section class="chat-section pt-0">
        <div class="custom-container">
            @* <h6 class="content-color fw-medium">Chat</h6> *@
            <ul class="chat-list" id="chatContactTab">
                <!-- Chat list items will be dynamically inserted here by GetUserChats() -->
            </ul>
        </div>
    </section>
    <!-- chat section end -->
</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.js"></script>
    <script src="~/lib/signalr/signalr.js"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/jalaaliConverter.js"></script>
    <script src="~/js/chatHub.js" asp-append-version="true"></script>
    <script src="~/js/fileManagement.js" asp-append-version="true"></script>
    <script src="~/js/audio-player.js" asp-append-version="true"></script>
    <script src="~/js/modal-lightbox.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

        });

        $(function () {
            GetUserChats();

            // When a chat is selected
            window.GetSelectedChatMessages = async function(chatId, groupType) {
                console.log(`بارگذاری چت: ${groupType}/${chatId}`);
                ChatActivated(chatId, groupType);

                // ۱. نمایش فوری اسکلت لودینگ
                const chatPanel = $('#chat-details-panel');
                chatPanel.html(createChatPanelSkeleton()).addClass('visible');

                // ۲. آماده‌سازی درخواست جامع
                const syncRequest = await window.chatApp.createSyncRequest(groupType, chatId);
                const requestData = {
                    chatId: chatId,
                    groupType: groupType,
                    syncRequest: syncRequest
                };

                // ۳. ارسال درخواست واحد به سرور
                $.ajax({
                    url: '/Home/GetInitialChatData',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(requestData),
                    success: async function(response) {
                        // ۴. پردازش پاسخ جامع

                        // الف) اعمال نتایج همگام‌سازی در کش
                        await window.chatApp.applySyncResult(groupType, chatId, response.syncResult);

                        // ب) رندر کردن پیام‌های دریافتی
                        // ابتدا یک partial view خالی با ساختار اصلی را رندر می‌کنیم
                        const initialChatHtml = createInitialChatView(chatId, groupType, response.lastReadMessageId);
                        chatPanel.html(initialChatHtml);
                        window.chatApp.renderMessages(response.messages, '#Message_Days');

                        // ج) نمایش و تنظیم شمارنده پیام‌های خوانده نشده
                        const notice = $('#unreadMessagesNotice');
                        if (response.unreadCount > 0 && notice.length) {
                            notice.find('#unreadCount').text(response.unreadCount);
                            notice.show();
                        } else if (notice.length) {
                            notice.hide();
                        }

                        // د) اسکرول هوشمند
                        let targetElement = null;
                        if (response.isFromUnread && response.lastReadMessageId) {
                             targetElement = document.getElementById(`message-${response.lastReadMessageId}`);
                             // اضافه کردن یک کلاس برای هایلایت کردن پیام
                             if(targetElement) $(targetElement).addClass('highlight-message');
                        }

                        if (targetElement) {
                            targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        } else {
                             $('#chat-finished')?.get(0)?.scrollIntoView({ block: 'end' });
                        }

                        // ه) فعال‌سازی مجدد کامپوننت‌ها و لیسنرها
                        window.chatApp.reAttachScrollListener();
                        if (typeof init_iconsax === 'function') {
                            init_iconsax();
                        }

                        // و) ذخیره پیام‌های جدید در کش
                        await window.chatApp.addOrUpdateMessages(groupType, chatId, response.messages);

                    },
                    error: function(error) {
                        console.error("خطا در دریافت داده‌های اولیه چت:", error);
                        chatPanel.find('#Message_Days').html('<p class="text-center text-danger p-5">خطا در بارگذاری پیام‌ها از سرور.</p>');
                    }
                });
            };

            function createChatPanelSkeleton() {
                return `
                    <div class="chat-header-skeleton"></div>
                    <div class="chat-content-skeleton">
                        <div id="Message_Days">
                             <div class="d-flex justify-content-center align-items-center h-100">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="chat-footer-skeleton"></div>`;
            }

            // When "Saved Messages" is selected
            window.GetSavedMessages = function() {
                $.ajax({
                    url: '/Home/GetSaveMessages',
                    type: 'GET',
                    success: function (data) {
                        $('#chat-details-panel').html(data).addClass('visible');

                        if (typeof init_iconsax === 'function') {
                            init_iconsax();
                        }
                    },
                    error: function (error) {
                        console.error("Error fetching saved messages:", error);
                    }
                });
            };

            // When closing the chat view to go back to the list
            $(document).on('click', '#close-chat-panel-btn', function() {
                $('#chat-details-panel').removeClass('visible');
                // Optional: clear content after animation
                setTimeout(function() {
                    $('#chat-details-panel').html('');
                }, 300);
            });

        });

        function GetUserChats() {
            $.ajax({
                url: '/Home/GetUserChats/',
                type: 'GET',
                success: function (data) {
                    $('#chatContactTab').html(data);
                    console.log("Class groups for user on loaded");
                    if (typeof init_iconsax === 'function') {
                       init_iconsax();
                    }
                },
                error: function (error) {
                    console.error("Error fetching class groups:", error);
                }
            });
        };

        function ChatActivated(chatId, groupType) {
             console.log(`chat Id and group type is : ${chatId} and ${groupType}`);
             var selectedChat = $(`#${groupType}_${chatId}`);
             const selectedChatId = `${groupType}_${chatId}`
             if(selectedChat.length) {
                 const chatItemsBody = $('#chatContactTab');
                 const chatItems = chatItemsBody.find('.active');
                 chatItems.removeClass('active');
                 selectedChat.addClass('active');

                 if (window.chatApp && window.chatApp.connection) {
                    if (window.activeGroupId) {
                        window.chatApp.connection.invoke("LeaveGroup", window.activeGroupId).catch(err => console.error('Error leaving group:', err));
                    }
                    window.chatApp.connection.invoke("JoinGroup", selectedChatId).catch(err => console.error('Error joining group:', err));
                 }
                 window.activeGroupId = selectedChatId;
             }
         }

        window.GetChatDetails = function(chatId, groupType){
             $.ajax({
                 url: '/Home/GetChatDetails',
                 type: 'GET',
                 data: { chatId: chatId, groupType: groupType },
                 success: function (data) {
                     $('#group-info-panel').html(data).addClass('visible');
                     if (typeof init_iconsax === 'function') {
                         init_iconsax();
                     }
                     // After the panel is visible, load the online status for members
                     if (window.chatApp && typeof window.chatApp.loadAndDisplayOnlineUsers === 'function') {
                         window.chatApp.loadAndDisplayOnlineUsers(chatId, groupType);
                     }
                 },
                 error: function (error) {
                     console.error("Error fetching chat members:", error);
                 }
             });
        }

        // When closing the group info panel to go back to the chat
        $(document).on('click', '#close-group-info-panel-btn', function (e) {
            e.preventDefault();
            $('#group-info-panel').removeClass('visible');
            // Optional: clear content after animation
            setTimeout(function () {
                $('#group-info-panel').html('');
            }, 300);
        });

            function createInitialChatView(chatId, groupType, lastReadMessageId) {
                // ایجاد ساختار HTML کامل برای پنل چت
                return `
                    <!-- header -->
                    <div class="chat-header">
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn back-btn d-lg-none" id="close-chat-panel-btn" type="button">
                                <i class="iconsax" data-icon="arrow-left"></i>
                            </button>
                            <div class="d-flex align-items-center gap-3" onclick="GetChatDetails('${chatId}', '${groupType}')" style="cursor:pointer;">
                                <div class="chat-user-img">
                                    <img class="img-fluid" src="/assets/media/avatar/UserIcon.png" alt="user" />
                                    <div class="active-status"></div>
                                </div>
                                <div class="chat-user-name">
                                    <h6 class="text-truncate" id="chat-group-name-in-header">...</h6>
                                    <span class="content-color d-block" id="chat-group-members-count-in-header">...</span>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-4">
                            <!-- Actions like call/video can be added here -->
                        </div>
                    </div>
                    <!-- / header -->

                    <!-- content -->
                    <div class="chat-content" id="chat_content">
                        <input type="hidden" id="current-group-id-hidden-input" value="${chatId}" />
                        <input type="hidden" id="current-group-type-hidden-input" value="${groupType}" />
                        <input type="hidden" id="lastReadMessageId" value="${lastReadMessageId || ''}" />
                        <input type="hidden" id="lastMessageIdLoad" value="0" />

                         <a class="btn" id="unreadMessagesNotice" style="display: none;">
                            <span id="unreadCount"></span> پیام خوانده نشده
                            <i class="iconsax" data-icon="arrow-down"></i>
                        </a>

                        <div id="Message_Days">
                            <!-- Messages will be rendered here by chatApp.renderMessages -->
                        </div>
                        <div id="chat-finished"></div>
                    </div>
                    <!-- / content -->

                    <!-- footer -->
                    <div class="chat-footer">
                         <div id="filePreviewContainer" class="file-preview-container"></div>
                         <div class="main-input-area">
                            <div id="reply-to-container" class="reply-preview-container" style="display: none;">
                                <div class="reply-content">
                                    <div class="reply-info">
                                        <span id="reply-to-user"></span>
                                        <span id="reply-to-text" class="text-truncate"></span>
                                    </div>
                                </div>
                                <button id="cancel-reply" class="btn-close"></button>
                            </div>
                            <div class="text-input-group">
                                <textarea class="form-control" id="message-input" placeholder="پیام شما..." rows="1"></textarea>
                                <button class="btn btn-attachment" type="button" id="attachment-btn" onclick="document.getElementById('file-upload-input').click();">
                                     <i class="iconsax" data-icon="paperclip-2"></i>
                                </button>
                                <input type="file" id="file-upload-input" multiple style="display:none;" />
                            </div>
                            <button class="btn btn-send" type="button" id="send-message-button">
                                <i class="iconsax" data-icon="send-1"></i>
                            </button>
                         </div>
                    </div>
                    <!-- / footer -->
                `;
            }

            // رویداد کلیک برای پرش به اولین پیام خوانده نشده
            $(document).on('click', '#unreadMessagesNotice', function() {
                const lastReadMessageId = $('#lastReadMessageId').val();
                if (lastReadMessageId) {
                    const targetElement = document.getElementById(`message-${lastReadMessageId}`);
                    if (targetElement) {
                        targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                         $(targetElement).addClass('highlight-message');
                         // هایلایت بعد از چند ثانیه محو شود
                        setTimeout(() => $(targetElement).removeClass('highlight-message'), 2000);
                    }
                }
                $(this).hide(); // مخفی کردن دکمه پس از کلیک
            });

    </script>
}
