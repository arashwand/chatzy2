@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_ChatzyLayout.cshtml";
}
@using System.Security.Claims
@using Messenger.Tools

@section Styles {
   
}

<input type="hidden" value="@User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value" id="userId" />
<input type="hidden" value="@User.Claims.FirstOrDefault(c => c.Type == "NameFamily")?.Value" id="fullName" />
<input type="hidden" value="@(ViewData["userProfilePic"] ?? "UserIcon.png")" id="userProfilePic" />
<input type="hidden" value="@(ViewData["baseUrl"] ?? "")" id="baseUrl" />
<input type="hidden" value="" id="groupType" />

<div id="main-content-body">
    <!-- story section starts -->
    @*   <section class="story-section pt-0">
        <div class="left-container">
            <h6 class="content-color fw-medium">Recent Update</h6>
            <div class="swiper story-box">
                <div class="swiper-wrapper">
                    <!-- Story items can be loaded here if needed -->
                </div>
            </div>
        </div>
    </section> *@
    <!-- story section end -->
    <!-- chat section starts -->
    <section class="chat-section pt-0">
        <div class="custom-container">
            @* <h6 class="content-color fw-medium">Chat</h6> *@
            <ul class="chat-list" id="chatContactTab">
                <!-- Chat list items will be dynamically inserted here by GetUserChats() -->
            </ul>
        </div>
    </section>
    <!-- chat section end -->
</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.js"></script>
    <script src="~/lib/signalr/signalr.js"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/jalaaliConverter.js"></script>
    <script src="~/js/chatHub.js" asp-append-version="true"></script>
    <script src="~/js/fileManagement.js" asp-append-version="true"></script>
    <script src="~/js/audio-player.js" asp-append-version="true"></script>
    <script src="~/js/modal-lightbox.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

        });

        $(function () {
            GetUserChats();

            // When a chat is selected
            window.GetSelectedChatMessages = async function(chatId, groupType) {
                console.log("chatId selected = " + chatId + " and groupType : " + groupType);
                ChatActivated(chatId, groupType);

                // ۱. ایجاد و نمایش فوری ساختار پایه UI
                const chatPanel = $('#chat-details-panel');
                const chatTitle = $(`#${groupType}_${chatId}`).find('.chat-name').text();
                const layoutHtml = createChatPanelLayout(chatId, groupType, chatTitle);
                chatPanel.html(layoutHtml).addClass('visible');
                if (typeof init_iconsax === 'function') {
                    init_iconsax();
                }

                // ۲. نمایش فوری پیام‌ها از کش
                try {
                    const cachedMessages = await getMessages(groupType, chatId);
                    if (cachedMessages && cachedMessages.length > 0) {
                        console.log(`Loaded ${cachedMessages.length} messages from cache.`);
                        window.chatApp.renderMessages(cachedMessages, '#Message_Days');
                        $('#chat-finished')?.get(0)?.scrollIntoView({ block: 'end' });
                    } else {
                        console.log("No messages in cache. Waiting for server...");
                    }
                } catch (err) {
                    console.error("Error reading from IndexedDB:", err);
                }
                window.chatApp.reAttachScrollListener();

                // ۳. همگام‌سازی و دریافت داده‌های نهایی از سرور در پس‌زمینه
                await window.chatApp.syncChatHistory(groupType, chatId);

                $.ajax({
                    url: '/Home/GetChatMessagesJson', // <-- Endpoint جدید
                    type: 'GET',
                    data: { chatId: chatId, groupType: groupType },
                    success: function (messages) {
                        if (messages && messages.length > 0) {
                            console.log(`Loaded ${messages.length} messages from server.`);
                            // رندر مجدد با داده‌های کامل سرور
                            window.chatApp.renderMessages(messages, '#Message_Days');

                            // ذخیره پیام‌های جدید در کش
                             saveMessages(groupType, chatId, messages);

                            // اسکرول هوشمند
                            // (این بخش می‌تواند بر اساس منطق lastReadMessageId که از سرور می‌آید، تکمیل شود)
                            $('#chat-finished')?.get(0)?.scrollIntoView({ block: 'end' });
                        }
                    },
                    error: function (error) {
                        console.error("Error fetching chat messages from server:", error);
                        $('#Message_Days').html('<p class="text-center text-danger p-5">خطا در بارگذاری پیام‌ها از سرور.</p>');
                    }
                });
            };

            function createChatPanelLayout(chatId, groupType, chatTitle) {
                return `
                    <input type="hidden" id="current-group-id-hidden-input" value="${chatId}" />
                    <input type="hidden" id="current-group-type-hidden-input" value="${groupType}" />
                    <header id="header" class="section-t-space main-header inner-page-header">
                        <div class="custom-container"><div class="header-panel contact-panel">
                            <div class="d-flex align-items-center gap-2">
                                <a href="#" id="close-chat-panel-btn"><i class="iconsax icon-btn" data-icon="chevron-left"></i></a>
                                <div class="profile-head">
                                    <div class="profile-img"><i class="iconsax" data-icon="group" style="font-size: 36px;"></i></div>
                                    <div><h4 class="fw-semibold">${chatTitle}</h4><small class="text-muted" id="typing-indicator-${chatId}"></small></div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-sm-3 gap-2">
                                <div class="dropdown more-options dropdown-menu-end">
                                    <a class="btn dropdown-toggle mt-0 p-0" href="#" role="button" data-bs-toggle="dropdown"><i class="iconsax icon-btn" data-icon="menu-meatballs"></i></a>
                                    <ul class="dropdown-menu"><li><a class="dropdown-item align-items-center d-flex" href="#" onclick="GetChatDetails('${chatId}', '${groupType}')"><i class="iconsax" data-icon="group"></i>&nbsp;<span>اعضای گروه</span></a></li></ul>
                                </div>
                            </div>
                        </div></div>
                    </header>
                    <section class="section-lg-b-space position-relative pt-0" id="chat_content">
                        <div class="custom-container">
                             <div id="Message_Days">
                                <div class="d-flex justify-content-center align-items-center h-100"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>
                             </div>
                             <div class="chat-finished" id="chat-finished"></div>
                        </div>
                    </section>
                     <div class="messages-panel">
                        <div class="action-banners-container">
                            <div id="cancel-edit-container" class="force-hide"><a href="#" id="cancel-edit-button">انصراف</a><div class="edit-indicator"><span class="edit-text">در حال ویرایش</span><div class="edit-bar"></div></div></div>
                            <div id="reply-to-container" style="display: none;"><div class="reply-indicator"><div class="reply-bar"></div><div class="reply-content"><div id="reply-thumbnail-container"></div><span id="reply-icon-container"></span><div class="reply-text-content"><span id="reply-to-user"></span><span id="reply-to-text"></span></div></div></div><a href="#" id="cancel-reply">انصراف</a></div>
                        </div>
                        <div id="filePreviewContainer"></div>
                        <form onsubmit="return false;" class="message-form-container">
                            <div id="text-input-area" class="message-inputarea">
                                <a href="#" onclick="$('#fileInput').click(); return false;"><i class="iconsax icon-btn" data-icon="picture-add"></i></a>
                                <a class="btn-record-voice"><i class="iconsax icon-btn" data-icon="mic-2"></i></a>
                                <textarea type="text" class="message-input" id="message-input" placeholder="Type here..." rows="1"></textarea>
                                <a href="#" class="" id="send-message-button"><i class="iconsax icon-btn" data-icon="send-btn1"></i></a>
                            </div>
                            <div id="voice-input-area" style="display: none;"></div>
                            <input type="file" id="fileInput" multiple style="display: none;" /><input type="hidden" id="uploadedFileIds" name="uploadedFileIds" /><input type="hidden" id="previousFileIds" name="previousFileIds" /><input type="hidden" id="deletUploadedFileIds" name="deletUploadedFileIds" /><input type="hidden" id="message-context-id" value="" /><input type="hidden" id="message-action-type" value="" />
                        </form>
                    </div>`;
            }

            // When "Saved Messages" is selected
            window.GetSavedMessages = function() {
                $.ajax({
                    url: '/Home/GetSaveMessages',
                    type: 'GET',
                    success: function (data) {
                        $('#chat-details-panel').html(data).addClass('visible');

                        if (typeof init_iconsax === 'function') {
                            init_iconsax();
                        }
                    },
                    error: function (error) {
                        console.error("Error fetching saved messages:", error);
                    }
                });
            };

            // When closing the chat view to go back to the list
            $(document).on('click', '#close-chat-panel-btn', function() {
                $('#chat-details-panel').removeClass('visible');
                // Optional: clear content after animation
                setTimeout(function() {
                    $('#chat-details-panel').html('');
                }, 300);
            });

        });

        function GetUserChats() {
            $.ajax({
                url: '/Home/GetUserChats/',
                type: 'GET',
                success: function (data) {
                    $('#chatContactTab').html(data);
                    console.log("Class groups for user on loaded");
                    if (typeof init_iconsax === 'function') {
                       init_iconsax();
                    }
                },
                error: function (error) {
                    console.error("Error fetching class groups:", error);
                }
            });
        };

        function ChatActivated(chatId, groupType) {
             console.log(`chat Id and group type is : ${chatId} and ${groupType}`);
             var selectedChat = $(`#${groupType}_${chatId}`);
             const selectedChatId = `${groupType}_${chatId}`
             if(selectedChat.length) {
                 const chatItemsBody = $('#chatContactTab');
                 const chatItems = chatItemsBody.find('.active');
                 chatItems.removeClass('active');
                 selectedChat.addClass('active');

                 if (window.chatApp && window.chatApp.connection) {
                    if (window.activeGroupId) {
                        window.chatApp.connection.invoke("LeaveGroup", window.activeGroupId).catch(err => console.error('Error leaving group:', err));
                    }
                    window.chatApp.connection.invoke("JoinGroup", selectedChatId).catch(err => console.error('Error joining group:', err));
                 }
                 window.activeGroupId = selectedChatId;
             }
         }

        window.GetChatDetails = function(chatId, groupType){
             $.ajax({
                 url: '/Home/GetChatDetails',
                 type: 'GET',
                 data: { chatId: chatId, groupType: groupType },
                 success: function (data) {
                     $('#group-info-panel').html(data).addClass('visible');
                     if (typeof init_iconsax === 'function') {
                         init_iconsax();
                     }
                     // After the panel is visible, load the online status for members
                     if (window.chatApp && typeof window.chatApp.loadAndDisplayOnlineUsers === 'function') {
                         window.chatApp.loadAndDisplayOnlineUsers(chatId, groupType);
                     }
                 },
                 error: function (error) {
                     console.error("Error fetching chat members:", error);
                 }
             });
        }

        // When closing the group info panel to go back to the chat
        $(document).on('click', '#close-group-info-panel-btn', function (e) {
            e.preventDefault();
            $('#group-info-panel').removeClass('visible');
            // Optional: clear content after animation
            setTimeout(function () {
                $('#group-info-panel').html('');
            }, 300);
        });

    </script>
}
